generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}
